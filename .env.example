# Firebase
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# LINE LIFF
VITE_LIFF_ID=your-liff-id

# Backend (Firebase Cloud Functions base URL)
# Example: https://asia-southeast1-your-project-id.cloudfunctions.net
VITE_API_BASE_URL=https://asia-southeast1-your-project-id.cloudfunctions.net

# Notion integration (Cloud Functions environment — set via Firebase secrets)
# Run: firebase functions:secrets:set NOTION_API_KEY
# Run: firebase functions:secrets:set NOTION_ATTENDANCE_DB_ID
# Run: firebase functions:secrets:set NOTION_LEAVE_DB_ID
NOTION_API_KEY=secret_...
NOTION_ATTENDANCE_DB_ID=your-attendance-database-id
NOTION_LEAVE_DB_ID=your-leave-requests-database-id
