# Production environment variables
# Copy this to .env.production and fill in real values

# Firebase (required)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firestore named database (optional, defaults to "(default)")
VITE_FIRESTORE_DB=db-checksure

# LINE LIFF (required)
VITE_LIFF_ID=

# Backend API (auto-derived from project ID in production)
# VITE_API_BASE_URL=https://asia-southeast1-YOUR_PROJECT.cloudfunctions.net
