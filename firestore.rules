rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read and write only their own profile.
    // The backend (Admin SDK) creates the document on first login;
    // the client may update preference fields (theme, lang, notifications).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Daily attendance records are private to the employee.
    match /attendance/{uid}/records/{date} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Leave requests are private to the employee.
    match /leaveRequests/{uid}/requests/{requestId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
